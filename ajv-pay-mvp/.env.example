# --- Serveur ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL ---
DATABASE_URL=postgres://ajvpay:ajvpay@localhost:5432/ajvpay

# --- Flooz (exemple — remplacer par les vraies credentials et chemins une fois la doc Flooz confirmée) ---
FLOOZ_API_BASE_URL=https://api.flooz.example.com
FLOOZ_API_KEY=changeme
FLOOZ_MERCHANT_CODE=changeme
FLOOZ_COLLECT_PATH=/v1/collect
FLOOZ_STATUS_PATH=/v1/collect
FLOOZ_REFUND_PATH=/v1/refund
FLOOZ_WEBHOOK_SECRET=
FLOOZ_WEBHOOK_SIGNATURE_HEADER=x-flooz-signature

# --- Moov Money (exemple) ---
MOOV_API_BASE_URL=https://api.moov.example.com
MOOV_API_KEY=changeme
MOOV_MERCHANT_CODE=changeme
MOOV_COLLECT_PATH=/v1/collect
MOOV_STATUS_PATH=/v1/collect
MOOV_REFUND_PATH=/v1/refund
MOOV_WEBHOOK_SECRET=
MOOV_WEBHOOK_SIGNATURE_HEADER=x-moov-signature

# --- CinetPay (carte bancaire + mobile money multi-opérateurs) ---
# API publique documentée : https://docs.cinetpay.com/api/1.0-fr/checkout
CINETPAY_API_BASE_URL=https://api-checkout.cinetpay.com/v2
CINETPAY_API_KEY=changeme
CINETPAY_SITE_ID=changeme
CINETPAY_NOTIFY_URL=https://api.ajvpay.example.com/webhooks/cinetpay
CINETPAY_RETURN_URL=https://ajvpay.example.com/payment/return

# --- Webhooks ---
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_RETRY_CRON=*/30 * * * * *
