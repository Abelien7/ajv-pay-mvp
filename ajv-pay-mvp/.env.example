# --- Serveur ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL ---
DATABASE_URL=postgres://ajvpay:ajvpay@localhost:5432/ajvpay

# --- Moov Money (Moov Africa, ex-Flooz) ---
MOOV_API_BASE_URL=https://api.moov.example.com
MOOV_API_KEY=changeme
MOOV_MERCHANT_CODE=changeme
MOOV_COLLECT_PATH=/v1/collect
MOOV_STATUS_PATH=/v1/collect
MOOV_REFUND_PATH=/v1/refund
MOOV_WEBHOOK_SECRET=
MOOV_WEBHOOK_SIGNATURE_HEADER=x-moov-signature

# --- Mixx by Yas (Togocom, ex-T-Money) ---
MIXX_API_BASE_URL=https://api.mixx.example.com
MIXX_API_KEY=changeme
MIXX_MERCHANT_CODE=changeme
MIXX_COLLECT_PATH=/v1/collect
MIXX_STATUS_PATH=/v1/collect
MIXX_REFUND_PATH=/v1/refund
MIXX_WEBHOOK_SECRET=
MIXX_WEBHOOK_SIGNATURE_HEADER=x-mixx-signature

# --- CinetPay (carte bancaire Visa/Mastercard, en redirection) ---
# Obtenus à l'ouverture d'un compte marchand sur cinetpay.com (demander
# l'offre "Marketplace/Partenaire" si le but est de revendre à tes propres
# marchands plutôt qu'encaisser uniquement pour AJV Pay lui-même).
CINETPAY_API_KEY=changeme
CINETPAY_SITE_ID=changeme
# URL publique de l'API AJV Pay + /webhooks/cinetpay (doit être joignable
# depuis Internet, donc l'URL Railway en prod, jamais localhost).
CINETPAY_NOTIFY_URL=https://votre-api.up.railway.app/webhooks/cinetpay
# Page où CinetPay renvoie le client après paiement (le dashboard, pas l'API).
CINETPAY_RETURN_URL=https://votre-dashboard.vercel.app/payment-return

# --- FedaPay (agrégateur mobile money/carte, automatise Moov Togo + Togocel) ---
# FEDAPAY_ENVIRONMENT: 'sandbox' pour tester (aucun vrai argent), 'live' une fois
# vérifié bout en bout. Clés séparées par environnement sur le dashboard FedaPay
# (sandbox.fedapay.com / live.fedapay.com — deux comptes distincts, pas juste un
# interrupteur). Ne JAMAIS committer de vraies clés ici, ce fichier est un modèle.
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_SECRET_KEY=changeme
FEDAPAY_PUBLIC_KEY=changeme
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_PHONE_COUNTRY=TG

# --- Paiement manuel (vérifié à la main par un admin AJV Pay) ---
# Numéro marchand affiché au client pour envoyer l'argent — un par réseau,
# car la syntaxe USSD (voir ManualPaymentsService) diffère entre les deux.
MANUAL_PAYMENT_NUMBER_MOOV=changeme
MANUAL_PAYMENT_NUMBER_MIXX=changeme
# Clé unique pour authentifier l'admin plateforme (toi) sur les routes
# /admin/manual-payments/* — distincte des clés API par marchand.
ADMIN_API_KEY=changeme

# --- Webhooks ---
# Livraison immédiate best-effort après chaque transition de paiement (voir
# PaymentOrchestrator) ; le service Railway "Worker" (worker.ts, @Cron en
# continu) reste le filet de sécurité pour ce qui échouerait à ce moment-là.
WEBHOOK_MAX_ATTEMPTS=5

# --- Dashboard (cookie de session) ---
# Origine EXACTE du dashboard (jamais de wildcard '*', incompatible avec les
# cookies de session dès que credentials:true est utilisé). Obligatoire en
# production (l'API refuse de démarrer sans elle si NODE_ENV=production).
CORS_ORIGIN=https://votre-dashboard.vercel.app

# --- Commission plateforme (optionnel, désactivée par défaut) ---
# Points de base (200 = 2%) prélevés sur chaque paiement 'live' réussi. Ne
# JAMAIS activer sans en informer les marchands déjà connectés au préalable.
PLATFORM_FEE_BPS=0

# --- Alertes (optionnel, désactivées si ALERT_WEBHOOK_URL absent) ---
# Webhook générique (compatible Slack/Discord/tout récepteur HTTP) si la
# file outbox ou les livraisons webhook s'accumulent — voir
# src/worker/alerting.service.ts.
ALERT_WEBHOOK_URL=
ALERT_OUTBOX_BACKLOG_THRESHOLD=20
ALERT_WEBHOOK_BACKLOG_THRESHOLD=20
ALERT_COOLDOWN_MINUTES=15
